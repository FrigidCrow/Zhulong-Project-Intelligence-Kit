{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frigidcrow.github.io/Zhulong-Project-Intelligence-Kit/schemas/milestone-contract.schema.json",
  "title": "Zhulong Milestone Contracts",
  "type": "object",
  "required": ["schemaVersion", "milestones"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "zhulong.milestone-contracts.v1"
    },
    "milestones": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "objective"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^MVP[0-9]+(?:\\.[0-9]+)?$" },
          "objective": { "type": "string", "minLength": 1 },
          "actions": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "enum": ["milestone", "spec", "discuss", "ui", "plan", "execute", "debug_fix", "review", "verify", "complete_milestone", "advance"]
            }
          },
          "allowedPaths": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "dependencies": { "type": "boolean" },
              "commit": { "type": "boolean" },
              "push": { "type": "boolean" },
              "merge": { "type": "boolean" },
              "release": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
